# Agent 连接的平台地址
PLATFORM_BASE_URL=http://10.226.98.1:8002

# 与平台约定的共享密钥（需与平台 .env 的 AGENT_SHARED_SECRET 一致）
AGENT_SHARED_SECRET=please-change-me

# Agent 节点标识
# AGENT_CODE可选：不填则根据 AGENT_NAME + AGENT_HOST 自动生成
# AGENT_CODE=node-sh-001
AGENT_NAME=Remote节点-001
# 建议留空自动探测本机IP（避免误填平台IP导致节点IP展示错误）
AGENT_HOST=
AGENT_PORT=9010

# Agent 启动后申请托管的项目代号，多个逗号分隔
# 允许留空；留空时不自动创建项目代号
AGENT_PROJECT_CODES=

# 默认管理员用户名：
# - 每次 Agent 注册都会写入数据库（只新增，不自动删除历史）
# - 当前 Agent 已绑定/新绑定项目会追加该用户为项目管理员（不存在则写预分配）
# - 即使 AGENT_PROJECT_CODES 为空，该用户仍可在平台上创建并默认绑定到该 Agent 的项目
AGENT_DEFAULT_ADMIN_USERNAME=admin

# 心跳上报间隔（秒）：同步在线状态，按需附带资源指标
AGENT_HEARTBEAT_INTERVAL_SECONDS=20
# 注册失败或鉴权失效后的重试间隔（秒）
AGENT_REGISTER_RETRY_INTERVAL_SECONDS=10
# 任务领取轮询间隔（秒）
AGENT_TASK_POLL_INTERVAL_SECONDS=3
# Agent 节点资源信息上传周期（秒），默认5分钟
AGENT_METRICS_INTERVAL_SECONDS=300
# （可选高级项）本地执行任务类型（逗号分隔）：
# - 不配置时默认全量本地执行
# - 支持项：auto_sync, commit_diff, excel_diff, weekly_sync, weekly_excel_cache, temp_cache_fetch
# AGENT_LOCAL_TASK_TYPES=auto_sync,commit_diff,excel_diff,weekly_sync,weekly_excel_cache,temp_cache_fetch
# 是否启用大结果临时缓存上报到平台（仅加速用途，可过期删除）
AGENT_TEMP_CACHE_UPLOAD_ENABLED=true
# 临时缓存上报阈值（字节），默认 1MB
AGENT_TEMP_CACHE_THRESHOLD_BYTES=1*1024_1024
# 临时缓存在平台侧的保留天数（默认 90 天）
AGENT_TEMP_CACHE_EXPIRE_DAYS=90
# 自更新：是否启用 release 包自动更新（默认开启）
AGENT_AUTO_UPDATE_ENABLED=true
# 自更新：检查新版本周期（秒）
AGENT_AUTO_UPDATE_CHECK_INTERVAL_SECONDS=60
# 自更新：查询发布信息接口超时（秒）
AGENT_AUTO_UPDATE_REQUEST_TIMEOUT_SECONDS=15
# 自更新：下载 release 包超时（秒）
AGENT_AUTO_UPDATE_DOWNLOAD_TIMEOUT_SECONDS=120
# 自更新：应用更新前是否自动安装 requirements
# - 使用“当前运行 Agent 的 Python 解释器”执行 `python -m pip install -r requirements.txt`
# - venv 和系统 Python 都可执行；推荐使用 venv，避免污染系统环境
AGENT_AUTO_UPDATE_INSTALL_DEPS=true
# 自更新：pip 安装依赖超时（秒）
AGENT_AUTO_UPDATE_PIP_TIMEOUT_SECONDS=900
# Agent 本地仓库目录
AGENT_REPOS_BASE_DIR=agent_repos
AGENT_LOG_VERBOSE=true
